# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 크롤링 대상 URL (grip.show 라이브예고 페이지)
# 실제 URL은 grip.show 내부 예고 페이지로 교체 필요
GRIP_LIVE_SCHEDULE_URL=https://grip.show/lives

# 크롤링 주기 (cron 표현식, 기본: 하루 3회 — 12시/18시/자정)
CRAWL_INTERVAL=0 0,12,18 * * *

# 생성된 소재 저장 경로
OUTPUT_DIR=./output

# Express API 서버 포트 (Figma 플러그인이 이 포트로 접속)
API_PORT=3000
